<!DOCTYPE html>
<html>
<head>
  <title>Login / Signup</title>
</head>
<body style="background: linear-gradient(to right, #d0f0fd, #e0ffe0); height: 100vh; margin: 0; display: flex; justify-content: center; align-items: center; font-family: Arial, sans-serif;">

  <div style="background-color: white; padding: 40px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); text-align: center;">
    <h1 style="margin-bottom: 30px; color: #333;">Welcome</h1>

    <%= link_to "Login", new_user_session_path, style: "display: inline-block; padding: 12px 25px; margin: 10px; background-color: #4facfe; color: white; text-decoration: none; border-radius: 5px; font-size: 16px;" %>

    <%= link_to "Sign Up", new_user_registration_path, style: "display: inline-block; padding: 12px 25px; margin: 10px; background-color: #00c9a7; color: white; text-decoration: none; border-radius: 5px; font-size: 16px;" %>
  </div>

</body>
</html>
