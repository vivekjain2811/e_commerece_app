<h1 style="text-align: center;"><%= @product.product_name %></h1>

<div style="width: 400px; margin: 0 auto; padding: 20px; border: 1px solid #ccc; border-radius: 10px; box-shadow: 2px 2px 10px rgba(0,0,0,0.1); text-align: left;">


  <% if @product.image.attached? %>
    <div style="text-align: center; margin-bottom: 15px;">
      <%= image_tag @product.image, style: "max-width: 100%; border-radius: 10px;" %>
    </div>
  <% end %>

  <p><strong>Price:</strong> ₹<%= number_to_currency(@product.product_price, unit: "", precision: 2) %></p>
  <p><strong>Available Stock:</strong> <%= @product.available_stock %></p>


  <% if @product.description.present? %>
    <div style="margin-top: 15px;">
      <strong>Description:</strong>
      <div style="padding: 10px; border: 1px solid #eee; border-radius: 5px; margin-top: 5px;">
        <%= @product.description %>
      </div>
    </div>
  <% end %>
<p><strong>Stock Status:</strong>
  <% if @product.in_stock? %>
    <span style="color: green;">In Stock</span>
  <% else %>
    <span style="color: red;">Out of Stock</span>
  <% end %>
</p>
<% if !@product.in_stock? %>
  <% if user_signed_in? %>
    <% unless @product.stock_notifications.exists?(user: current_user) %>
      <%= button_to "Notify Me When Available", stock_notifications_path(product_id: @product.id), method: :post, class: "btn", style: "margin-top: 10px;" %>
    <% else %>
      <p style="color: green; margin-top: 10px;">You’ll be notified when this is back in stock.</p>
    <% end %>
  <% else %>
    <%= link_to "Login to get notified", new_user_session_path, style: "color: blue;" %>
  <% end %>
<% end %>

  <div style="margin-top: 20px;">
    <% if user_signed_in? && current_user == @product.user %>
      <%= link_to "Edit", edit_product_path(@product), style: "margin-right: 10px; color: #ffc107; text-decoration: none;" %>
    <% end %>

    <%= link_to "Back to Products", products_path, style: "color: #007bff; text-decoration: none;" %>
  </div>
</div>
