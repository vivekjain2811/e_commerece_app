<h1 style="text-align: center;">All Products</h1>

<div style="text-align: center; margin-bottom: 20px;">
  <%= link_to "Add New Product", new_product_path, style: "padding: 10px 15px; background-color: #28a745; color: white; text-decoration: none; border-radius: 5px;" %>
</div>

<div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">
  <% @products.each do |product| %>
    <div style="border: 1px solid #ddd; border-radius: 10px; padding: 15px; width: 250px; box-shadow: 2px 2px 10px rgba(0,0,0,0.1);">
      <h3 style="margin-top: 0;"><%= product.product_name %></h3>
      <p><strong>Price:</strong> ₹<%= number_to_currency(product.product_price, unit: "", precision: 2) %></p>
      <p><strong>Stock:</strong> <%= product.available_stock %></p>

      <div style="margin-top: 10px;">
        <%= link_to "Show", product_path(product), style: "margin-right: 5px; text-decoration: none; color: #007bff;" %>
        <% if user_signed_in? && current_user == product.user %>
            <%= link_to "Edit", edit_product_path(product), style: "margin-right: 5px; text-decoration: none; color: #ffc107;" %>
            <%= button_to "Delete", product_path(product), method: :delete, data: { confirm: "Are you sure?" }, style: "background-color: #dc3545; color: white; padding: 8px 16px; border: none; border-radius: 5px; cursor: pointer;" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
 <div style="text-align: center; margin-top: 20px;">
  <%= button_to "Logout", destroy_user_session_path, method: :delete, style: "padding: 10px 20px; background-color: #f44336; color: white; border: none; border-radius: 5px; cursor: pointer;" %>
</div>